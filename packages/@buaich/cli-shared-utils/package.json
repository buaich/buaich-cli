{
  "name": "@buaich/cli-shared-utils",
  "version": "2.0.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/buaich/buaich-cli",
    "directory": "packages/@buaich/cli-shared-utils"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
