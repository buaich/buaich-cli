{
    "compilerOptions": {
        "target": "es2022", //指定编译后的 JavaScript版本
        "module": "nodenext", // 指定生成的JavaScript所使用的模块系统
        "moduleResolution": "nodenext", //指定模块解析策略
        "types": ["node"], //启用Node.js内置模块（path/fs 等）的类型
        "outDir": "./dist", //指定编译后的文件输出目录
        "rootDir": "./src", //指定TypeScript源文件的根目录
        "strict": true, //启用严格模式
        "ignoreDeprecations": "6.0", //消除 TS6 对弃用选项的报错（TS5101）
        "esModuleInterop": true, //启用esModuleInterop以允许默认导入非ES模块
        "skipLibCheck": true, //跳过库文件的类型检查
        "declaration": true //为每个TypeScript源文件生成相应的.d.ts文件
    },
    "include": ["src/**/*"], //指定要编译的文件或目录
    "exclude": ["node_modules", "dist", "src/templates"] //指定要排除的文件或目录
}